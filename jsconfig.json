{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "ES2024",
        "jsx": "react-jsx",
        "allowImportingTsExtensions": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strict": true,
        "checkJs": true,
        "noEmit": true,
    },
    "exclude": [
        "public/*",
        "**/node_modules/*"
    ]
}